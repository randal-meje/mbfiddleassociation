# Copy to .env and fill in the values from https://www.sanity.io/manage after creating
# the Sanity project. .env is gitignored.

# Sanity Studio — reads these (via dotenv) when running `npm run studio`.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Astro build — reads these (via Vite) at build time when fetching content from Sanity.
# Must match the project above.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Cloudflare Web Analytics (optional) — leave blank to disable. Paste the token from
# https://one.dash.cloudflare.com → Analytics & Logs → Web Analytics → your site → Snippet.
PUBLIC_CF_ANALYTICS_TOKEN=
