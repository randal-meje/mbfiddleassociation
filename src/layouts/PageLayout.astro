---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  subtitle?: string;
}
const { title, description, eyebrow, subtitle } = Astro.props;
---

<BaseLayout title={`${title} — Manitoba Fiddle Association`} description={description}>
  <article class="mx-auto max-w-3xl px-6 py-12 md:py-16">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-700">{eyebrow}</p>
    )}
    <h1 class="mt-2 font-serif text-4xl md:text-5xl font-semibold text-ink text-balance leading-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-3 font-serif text-xl md:text-2xl text-brand-800 leading-snug text-balance">{subtitle}</p>
    )}
    <div class="mt-8 prose prose-neutral max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
