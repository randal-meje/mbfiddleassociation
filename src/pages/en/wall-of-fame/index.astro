---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getInducteeYears, getAllInductees } from '../../../sanity/queries';

const years = await getInducteeYears();
const all = await getAllInductees();

// Group inductees by year for the year cards, and totals by category for the landing blurb.
const byYear = new Map<number, typeof all>();
for (const i of all) {
  if (!byYear.has(i.year)) byYear.set(i.year, []);
  byYear.get(i.year)!.push(i);
}

const CATEGORY_LABEL: Record<string, string> = {
  fiddler: 'Fiddler',
  accompanist: 'Accompanist',
  builder: 'Builder / Promoter',
  other: 'Other',
};
---

<BaseLayout
  title="Wall of Fame — Manitoba Fiddle Association"
  description="The Manitoba Fiddle Association Wall of Fame honours fiddlers, accompanists, and community builders who have shaped our province's fiddle tradition."
>
  <article class="mx-auto max-w-5xl px-6 py-12 md:py-16">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-700">Wall of Fame</p>
    <h1 class="mt-2 font-serif text-4xl md:text-5xl font-semibold text-ink text-balance leading-tight">
      Honouring Manitoba's fiddle tradition
    </h1>
    <p class="mt-4 text-lg text-ink/75 max-w-2xl leading-relaxed">
      The Wall of Fame is where we recognize the fiddlers, accompanists, and community
      builders whose work has preserved and passed on fiddle music in this province.
      Select a year below to see that year's inductees.
    </p>

    {years.length === 0 && (
      <p class="mt-12 text-ink/70 italic">No inductees have been added yet.</p>
    )}

    <div class="mt-12 grid gap-4 sm:grid-cols-2 md:grid-cols-3">
      {years.map((y) => {
        const cohort = byYear.get(y) ?? [];
        return (
          <a
            href={`/en/wall-of-fame/${y}`}
            class="group flex flex-col rounded-lg border border-neutral-200 bg-white p-5 no-underline transition hover:border-brand-700 hover:shadow-sm"
          >
            <span class="font-serif text-3xl font-semibold text-ink group-hover:text-brand-700">{y}</span>
            <span class="mt-2 text-sm text-ink/70">
              {cohort.length} {cohort.length === 1 ? 'inductee' : 'inductees'}
            </span>
            <ul class="mt-3 space-y-1 text-sm text-ink/80">
              {cohort.slice(0, 4).map((i) => (
                <li class="flex items-baseline justify-between gap-2">
                  <span>
                    {i.name}
                    {i.posthumous && <span class="text-ink/55"> (posthumous)</span>}
                  </span>
                  <span class="text-xs uppercase tracking-wider text-ink/50 text-right">{CATEGORY_LABEL[i.category] ?? i.category}</span>
                </li>
              ))}
              {cohort.length > 4 && (
                <li class="text-xs text-ink/50">and {cohort.length - 4} more…</li>
              )}
            </ul>
          </a>
        );
      })}
    </div>
  </article>
</BaseLayout>
